# Copy to .envrc or source manually before running npm run start:http.
CODEXPRO_ROOT=/absolute/path/to/your/repo
CODEXPRO_ALLOWED_ROOTS=/absolute/path/to
CODEXPRO_HOST=127.0.0.1
CODEXPRO_PORT=8787
CODEXPRO_BASH_MODE=safe
# Optional: allow safe bash to run workspace-relative .py scripts.
# Set to "workspace" to allow any .py file inside the workspace path guard.
# CODEXPRO_SAFE_PYTHON=workspace
# Or use a stricter comma-separated allowlist:
# CODEXPRO_SAFE_PYTHON_SCRIPTS=
# Optional local bash session guard. If required, bash tool calls must include the matching session_id.
# CODEXPRO_BASH_SESSION_ID=main
# CODEXPRO_REQUIRE_BASH_SESSION=1
# Optional: queue document-like changes from write/edit/move/bash and commit them as one batch.
# The batch commits after MCP tool calls have been idle for this workspace.
# CODEXPRO_AUTO_COMMIT_DOCS=1
# CODEXPRO_AUTO_COMMIT_DOCS_IDLE_MS=120000
# CODEXPRO_AUTO_COMMIT_DOC_EXTENSIONS=.md,.mdx,.txt,.docx,.pptx,.xlsx,.csv,.pdf,.png,.jpg,.jpeg,.webp,.svg
CODEXPRO_WRITE_MODE=handoff
CODEXPRO_TOOL_MODE=standard
# Optional caps for local images returned through the read_image/read_images MCP tools.
# CODEXPRO_MAX_IMAGE_BYTES=4000000
# Optional total cap for one read_images batch.
# CODEXPRO_MAX_IMAGE_BATCH_BYTES=20000000
# Optional dedicated HTTPS origin for ChatGPT widget iframes.
# Leave unset to use ChatGPT's default OpenAI sandbox origin.
# Required for app submission if you enable custom tool cards.
# CODEXPRO_WIDGET_DOMAIN=https://widgets.example.com

# Disabled by default so ChatGPT receives plain MCP tool descriptors.
# Set to 1 only if you want CodexPro's custom ChatGPT cards.
CODEXPRO_TOOL_CARDS=0
CODEXPRO_HTTP_TOKEN=replace-with-a-long-random-token
# Require a token even for loopback binds. Non-loopback and tunnel mode require one unless explicitly overridden.
# CODEXPRO_REQUIRE_HTTP_TOKEN=1
# CODEXPRO_ALLOW_NO_HTTP_TOKEN=1
CODEXPRO_CONTEXT_DIR=.ai-bridge
# Optional stable public URL mode. Quick tunnels do not keep the same hostname.
# CODEXPRO_TUNNEL=cloudflare-named
# CODEXPRO_PUBLIC_HOSTNAME=codexpro.example.com
# CLOUDFLARE_TUNNEL_NAME=codexpro
# Or use a dashboard-managed tunnel token:
# CLOUDFLARE_TUNNEL_TOKEN_FILE=/Users/you/.codexpro/cloudflare-tunnel-token
# Optional comma-separated extra block list:
# CODEXPRO_BLOCKED_GLOBS=**/secrets/**,**/*.sqlite,**/*.db
